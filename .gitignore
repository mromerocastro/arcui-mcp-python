# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets / credentials — never commit
.env
.env.*
!.env.example
*.pem
*.key

# IDE / editor settings (may contain machine-local paths or auth)
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db

# Local validation artifacts (e.g. plots from manual testing)
test.png
*.tmp

# Local Knowledge Pack runtime data + ad-hoc indexing scripts.
# chroma/ is the on-disk ChromaDB store; index_*.py are personal helper
# scripts that often hardcode machine-local document paths — never commit.
chroma/
index_*.py

# Jupyter checkpoints
.ipynb_checkpoints/
